# ============================================================
# Python Virtual Environment (NEVER push this to GitHub)
# ============================================================
venv/
.venv/
env/
ENV/

# ============================================================
# Python Cache Files
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# ============================================================
# Environment & Secret Files (CRITICAL - never push secrets)
# ============================================================
.env
.env.*
!.env.example
*.key
*.pem
*.secret

# ============================================================
# Generated / Processed Data (can be regenerated)
# ============================================================
app/data/processed/*.json
app/data/processed/*.pkl
app/data/processed/*.npy

# ============================================================
# Machine Learning Model Files (too large for GitHub)
# ============================================================
*.pkl
*.h5
*.hdf5
*.ckpt
*.pt
*.pth
models/

# ============================================================
# OS & Editor Files
# ============================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ============================================================
# Logs
# ============================================================
*.log
logs/
uvicorn.log

# ============================================================
# Distribution / Build
# ============================================================
dist/
build/
*.egg-info/
.eggs/
